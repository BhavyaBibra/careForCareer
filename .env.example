# Server
APP_ENV=development
API_PORT=8080

# Database
DATABASE_URL=postgres://careergps:secret@localhost:5432/careergps?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=careergps-resumes
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# JWT
JWT_PRIVATE_KEY_PATH=./config/keys/private.pem
JWT_PUBLIC_KEY_PATH=./config/keys/public.pem
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
LLM_PRIMARY_PROVIDER=anthropic
LLM_CACHE_TTL_HOURS=24

# Rate Limits
COACH_DAILY_LIMIT=20
RATE_LIMIT_UNAUTHENTICATED=30
RATE_LIMIT_AUTHENTICATED=100

# Scoring Engine
SCORING_WEIGHTS_PATH=./config/scoring_weights.yaml
SCORING_ENGINE_VERSION=v1.0.0

# Observability
OTEL_EXPORTER_PROMETHEUS_PORT=9090
LOG_LEVEL=info
